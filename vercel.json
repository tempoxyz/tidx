{
  "redirects": [
    {
      "source": "/install",
      "destination": "/install.sh",
      "statusCode": 302
    },
    {
      "source": "/docker",
      "destination": "/scripts/docker.sh",
      "statusCode": 302
    }
  ],
  "headers": [
    {
      "source": "/scripts/:path*",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/docker/:path*",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
